nextflow_process {
    name "Test MYTOOL_RUN"
    script "../main.nf"
    process "MYTOOL_RUN"

    test("sarscov2 - fastq stub") {
        options "-stub"
        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success }
            )
        }
    }
}
